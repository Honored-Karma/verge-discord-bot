# Discord Bot Configuration
# Get these values from https://discord.com/developers/applications

# Your bot token (REQUIRED)
DISCORD_TOKEN=your_token_here

# Your application/client ID (REQUIRED for command deployment)
CLIENT_ID=your_client_id_here

# MongoDB URI (REQUIRED)
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=AppName
MONGODB_URI=your_mongodb_uri_here