# Discord Bot Configuration
# Get these values from https://discord.com/developers/applications

# Your bot token (REQUIRED)
DISCORD_TOKEN=your_token_here

# Your application/client ID (REQUIRED for command deployment)
CLIENT_ID=your_client_id_here

# MongoDB URI (REQUIRED)
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=AppName
MONGODB_URI=your_mongodb_uri_here

# Admin user IDs (comma-separated)
ADMIN_IDS=user_id_1,user_id_2

# Guild ID for deployment
GUILD_ID=your_guild_id_here

# Role IDs for limited admin commands (add-ap, add-sp, add-currency, etc)
LIMITED_ADMIN_ROLE_IDS=role_id_1,role_id_2

# Role IDs for style-giving commands (give-style)
GIVE_STYLE_ROLE_IDS=role_id_3,role_id_4

# Weekly salary scheduler
# Every Monday 12:00 (UTC) by default
SALARY_CRON=0 12 * * 1
SALARY_TIMEZONE=UTC
SALARY_LOG_CHANNEL_ID=channel_id_for_salary_logs

# Optional emoji prefixes for Discohook parser command
UI_TITLE_EMOJI=✨
UI_FIELD_EMOJI=🔹
