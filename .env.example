# Discord Bot Configuration
# Get these values from https://discord.com/developers/applications

# Your bot token (REQUIRED)
DISCORD_TOKEN=your_bot_token_here

# Your application/client ID (REQUIRED for command deployment)
CLIENT_ID=your_client_id_here

# Guild ID for development (OPTIONAL - for faster command deployment during testing)
# If not set, commands will be deployed globally (takes up to 1 hour)
GUILD_ID=your_guild_id_here

# Admin user IDs (OPTIONAL - comma-separated list)
# Users in this list will have admin permissions along with "Game Master" role holders
ADMIN_IDS=123456789012345678,987654321098765432
